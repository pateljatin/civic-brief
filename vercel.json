  "crons": [
    { "path": "/api/cron/ingest", "schedule": "0 6 * * *" },
    { "path": "/api/cron/digest", "schedule": "0 9 * * 1" }
  ],
  "functions": {
    "src/app/api/summarize/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/translate/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/verify/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/internal/ingest-feed/route.ts": {
      "maxDuration": 300
    }
  }
}
