# Civic Brief Environment Variables
# Copy to .env.local and fill in values (never commit .env.local)

# ─── Core (required for demo) ───
ANTHROPIC_API_KEY=              # Claude API key (console.anthropic.com)
NEXT_PUBLIC_SUPABASE_URL=       # Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # Supabase publishable/anon key
SUPABASE_SERVICE_ROLE_KEY=      # Supabase secret/service role key

# ─── Feed Ingestion (C7) ───
CRON_SECRET=                    # Auto-injected by Vercel in production
INGEST_HMAC_SECRET=             # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPENSTATES_API_KEY=             # Free: https://openstates.org/accounts/signup/
INGESTION_DAILY_LIMIT=50        # Max auto-ingested docs per day

# ─── Email (optional) ───
RESEND_API_KEY=                 # https://resend.com
ADMIN_EMAIL=                    # Feed failure alerts + weekly digest recipient
